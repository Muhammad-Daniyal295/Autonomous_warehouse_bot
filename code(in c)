/*
 * ============================================================
 *  Line Follower PIC18F4550
 *  Compiler : MPLAB XC8 v2.x
 *  Oscillator: 8 MHz internal
 * ============================================================
 *
 *  L298 Motor Driver wiring
 * 
 *  ENA (Right motor speed)  RC2  (CCP1 / Hardware PWM)
 *  IN1 (Right Forward)      RD0
 *  IN2 (Right Backward)    RD4
 *  ENB (Left motor speed)  RC1  (CCP2 / Hardware PWM)
 *  IN3 (Left Forward)      RD2
 *  IN4 (Left Backward)     RD3
 *
 *  IR Sensors  (active HIGH = black line detected)
 * 
 * LL (outer left)  â?? RB4
 *  L                â?? RB3
 *  C  (centre)      â?? RB2
 *  R                â?? RB1
 *  RR (outer right) â?? RB0
 *
 *  Servo Motor (PORTD)
 * 
 *  Signal â?? RD5  (50 Hz, 1ms = CW, 2ms = CCW)
 *
 *  Color Sensor TCS3200 (PORTA) â?? CONNECTIONS DEFINED ONLY
 * 
 * S0 â?? RA0, S1 â?? RA1, S2 â?? RA2, S3 â?? RA3, OUT â?? RA4
 *
 *  Ultrasonic HC-SR04 (PORTE) â?? CONNECTIONS DEFINED ONLY
 * 
 * ============================================================
 */

#include <xc.h>
#include <stdint.h>


#define _XTAL_FREQ  8000000UL


#pragma config FOSC    = INTOSC_HS   // 8 MHz internal oscillator
#pragma config PWRT    = OFF
#pragma config BOR     = OFF
#pragma config BORV    = 3
#pragma config WDT     = OFF
#pragma config WDTPS   = 32768
#pragma config MCLRE   = ON
#pragma config LPT1OSC = OFF
#pragma config PBADEN  = OFF
#pragma config CCP2MX  = ON            // CCP2 on RC1
#pragma config STVREN  = ON
#pragma config LVP     = OFF
#pragma config XINST   = OFF
#pragma config CP0     = OFF
#pragma config CP1     = OFF
#pragma config CPB     = OFF
#pragma config CPD     = OFF
#pragma config WRT0    = OFF
#pragma config WRT1    = OFF
#pragma config WRTB    = OFF
#pragma config WRTD    = OFF
#pragma config EBTR0   = OFF
#pragma config EBTR1   = OFF
#pragma config EBTRB   = OFF


#define TIMER0_RELOAD  (65536UL - (_XTAL_FREQ / 4UL / 1000UL))
#define TIMER0_H       ((uint8_t)(TIMER0_RELOAD >> 8))
#define TIMER0_L       ((uint8_t)(TIMER0_RELOAD & 0xFF))


#define IN1   LATDbits.LATD0    // Right motor â?? Forward
#define IN2   LATDbits.LATD4    // Right motor â?? Backward
#define IN3   LATDbits.LATD2    // Left  motor â?? Forward
#define IN4   LATDbits.LATD3    // Left  motor â?? Backward


#define PIN_LL  PORTBbits.RB4
#define PIN_L   PORTBbits.RB3
#define PIN_C   PORTBbits.RB2
#define PIN_R   PORTBbits.RB1
#define PIN_RR  PORTBbits.RB0

/* â??â?? Color Sensor TCS3200 (PORTA) â?? DEFINED, NOT IMPLEMENTED â??â??â??â?? */
#define TCS_S0  LATAbits.LATA0
#define TCS_S1  LATAbits.LATA1
#define TCS_S2  LATAbits.LATA2
#define TCS_S3  LATAbits.LATA3
#define TCS_OUT PORTAbits.RA4


#define ULTRASONIC_TRIG  LATEbits.LATE0
#define ULTRASONIC_ECHO  PORTEbits.RE1


#define SERVO_PIN LATDbits.LATD5

/* ================================================================
 *  TUNING PARAMETERS
 * ================================================================ */

/* Line-following P-controller */
#define BASE_SPEED          163
#define KP                  18
#define DIR_THRESHOLD       2

/* Lost-line recovery */
#define RECOVERY_SPEED      220
#define GAP_COAST_TIME      120UL   // ms to coast before spinning

/* Junction detection debounce */
#define JUNCTION_CONFIRM_MS   20UL
#define JUNCTION_COOLDOWN_MS 300UL

/* Turn execution */
#define TURN_SPEED            170
#define OVERSHOOT_SPEED        90
#define JUNCTION_OVERSHOOT_MS  60UL
#define TURN_SETTLE_MS        500UL

/* Startup hold */
#define STARTUP_HOLD_MS      1000UL



typedef enum { STRAIGHT = 0, TURN_LEFT, TURN_RIGHT, DETOUR_LEFT_CW, DETOUR_LEFT_CCW, ROUTE_END } Action;

#define PATH_LENGTH  15
const Action path[PATH_LENGTH] = {
    STRAIGHT,           // junction 1
    STRAIGHT,           // junction 2
    TURN_LEFT,          // junction 3
    STRAIGHT,           // junction 4
    STRAIGHT,           // junction 5
    STRAIGHT,           // junction 6
    TURN_LEFT,          // junction 7
    DETOUR_LEFT_CW,     // junction 8 â? servo CLOCKWISE
    STRAIGHT,           // junction 9
    TURN_RIGHT,         // junction 10
    STRAIGHT,           // junction 11
    STRAIGHT,           // junction 12
    DETOUR_LEFT_CCW,    // junction 13 â? servo COUNTER-CLOCKWISE
    TURN_RIGHT,         // junction 14
    ROUTE_END           // end
};


/* ================================================================
 *  millis() via Timer0 ISR
 * ================================================================ */
volatile uint32_t _ms = 0;

void __interrupt(high_priority) ISR_High(void)
{
    if (INTCONbits.TMR0IF)
    {
        INTCONbits.TMR0IF = 0;
        TMR0H = TIMER0_H;   // high byte MUST be written first
        TMR0L = TIMER0_L;
        _ms++;
    }
}

static uint32_t millis(void)
{
    uint32_t m;
    INTCONbits.GIEH = 0;    // brief atomic read
    m = _ms;
    INTCONbits.GIEH = 1;
    return m;
}

/* Blocking delay using millis â?? safe inside main, NOT inside ISR */
static void delay_ms(uint32_t ms)
{
    uint32_t t = millis();
    while (millis() - t < ms);
}


/* ================================================================
 *  Hardware init
 * ================================================================ */
static void Timer0_Init(void)
{
    T0CON              = 0x88;  // TMR0ON, 16-bit, Fosc/4, no prescaler
    TMR0H              = TIMER0_H;
    TMR0L              = TIMER0_L;
    RCONbits.IPEN      = 1;     // enable priority levels
    INTCON2bits.TMR0IP = 1;     // Timer0 â?? high priority
    INTCONbits.TMR0IF  = 0;
    INTCONbits.TMR0IE  = 1;
    INTCONbits.GIEH    = 1;     // global high-priority interrupt enable
}

static void PWM_Init(void)
{
    TRISCbits.TRISC2 = 0;   // ENA â?? output
    TRISCbits.TRISC1 = 0;   // ENB â?? output
    TRISDbits.TRISD5 = 0;   // Servo â?? output
    TRISAbits.TRISA4 = 1;   // TCS_OUT â?? input (color sensor)

    PR2     = 0xFF;          // PWM period
    T2CON   = 0x04;          // Timer2 ON, prescale 1:1

    CCPR1L  = 0; CCP1CON = 0x0C;   // CCP1 PWM mode
    CCPR2L  = 0; CCP2CON = 0x0C;   // CCP2 PWM mode
}

/* ================================================================
 *  Color Sensor Type
 * ================================================================ */
typedef enum { COLOR_RED = 0, COLOR_BLUE, COLOR_UNKNOWN } Color;

/* ================================================================
 *  TCS3200 Color Sensor Functions
 * ================================================================ */
static void TCS_Init(void)
{
    /* Set frequency scaling to 20% (S0=1, S1=0) */
    TCS_S0 = 1;
    TCS_S1 = 0;
}

static uint16_t tcsReadChannel(void)
{
    /* Count pulses on TCS_OUT for 100 ms */
    uint16_t count = 0;
    uint32_t start = millis();
    uint8_t prev = TCS_OUT;

    while (millis() - start < 100UL)
    {
        uint8_t cur = TCS_OUT;
        if (cur == 0 && prev == 1) count++;  // count falling edges
        prev = cur;
    }
    return count;
}

static Color readColor(void)
{
    uint16_t red, green, blue;

    /* Read RED channel: S2=0, S3=0 */
    TCS_S2 = 0; TCS_S3 = 0;
    delay_ms(10);
    red = tcsReadChannel();

    /* Read GREEN channel: S2=1, S3=1 */
    TCS_S2 = 1; TCS_S3 = 1;
    delay_ms(10);
    green = tcsReadChannel();

    /* Read BLUE channel: S2=0, S3=1 */
    TCS_S2 = 0; TCS_S3 = 1;
    delay_ms(10);
    blue = tcsReadChannel();

    /* Determine dominant colour (higher count = more of that colour) */
    if (red > green && red > blue)
        return COLOR_RED;
    if (blue > red && blue > green)
        return COLOR_BLUE;
    return COLOR_UNKNOWN;
}


/* ================================================================
 *  Motor helpers
 * ================================================================ */
static inline void PWM_Right(uint8_t duty)
{
    CCPR1L            = duty;
    CCP1CONbits.DC1B1 = 0;
    CCP1CONbits.DC1B0 = 0;
}

static inline void PWM_Left(uint8_t duty)
{
    CCPR2L            = duty;
    CCP2CONbits.DC2B1 = 0;
    CCP2CONbits.DC2B0 = 0;
}

/* Signed â??255â?¦+255: positive = forward, negative = backward */
static void setMotors(int16_t left, int16_t right)
{
    if (left  >  255) left  =  255;
    if (left  < -255) left  = -255;
    if (right >  255) right =  255;
    if (right < -255) right = -255;

    if (left  >= 0) { IN3 = 1; IN4 = 0; PWM_Left ((uint8_t) left);  }
    else            { IN3 = 0; IN4 = 1; PWM_Left ((uint8_t)-left);  }

    if (right >= 0) { IN1 = 1; IN2 = 0; PWM_Right((uint8_t) right); }
    else            { IN1 = 0; IN2 = 1; PWM_Right((uint8_t)-right); }
}


/* ================================================================
 *  Servo Motor Control â?? 50 Hz PWM pulses
 *  1ms = Clockwise, 2ms = Counter-clockwise
 * ================================================================ */
static void servoClockwise(void)
{
    uint8_t i;
    for (i = 0; i < 50; i++)
    {
        INTCONbits.GIEH = 0;
        SERVO_PIN = 1;
        __delay_us(1000);     // 1 ms = CW
        SERVO_PIN = 0;
        INTCONbits.GIEH = 1;
        delay_ms(18);
    }
    for (i = 0; i < 10; i++)
    {
        INTCONbits.GIEH = 0;
        SERVO_PIN = 1;
        __delay_us(1500);     // neutral
        SERVO_PIN = 0;
        INTCONbits.GIEH = 1;
        delay_ms(18);
    }
}

static void servoCounterClockwise(void)
{
    uint8_t i;
    for (i = 0; i < 50; i++)
    {
        INTCONbits.GIEH = 0;
        SERVO_PIN = 1;
        __delay_us(2000);     // 2 ms = CCW
        SERVO_PIN = 0;
        INTCONbits.GIEH = 1;
        delay_ms(18);
    }
    for (i = 0; i < 10; i++)
    {
        INTCONbits.GIEH = 0;
        SERVO_PIN = 1;
        __delay_us(1500);     // neutral
        SERVO_PIN = 0;
        INTCONbits.GIEH = 1;
        delay_ms(18);
    }
}


/* ================================================================
 *  Turn routines (unchanged from original)
 * ================================================================ */
static void executeTurnLeft(void)
{
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(-TURN_SPEED, TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(-TURN_SPEED, TURN_SPEED);
}

static void executeTurnRight(void)
{
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(TURN_SPEED, -TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(TURN_SPEED, -TURN_SPEED);
}


/* ================================================================
 *  Detour routines with servo actuation
 * ================================================================ */
static void executeDetourLeftCW(void)
{
    /* Turn left onto side line */
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(-TURN_SPEED, TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(-TURN_SPEED, TURN_SPEED);

    /* Stop and wait 2 seconds for stable colour reading */
    setMotors(0, 0);
    delay_ms(2000);

    /* Read colour and move servo accordingly:
     * RED  â?? Clockwise
     * BLUE â?? Counter-clockwise */
    Color detected = readColor();
    if (detected == COLOR_RED)
        servoClockwise();
    else if (detected == COLOR_BLUE)
        servoCounterClockwise();

    /* Turn right to rejoin main line */
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(TURN_SPEED, -TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(TURN_SPEED, -TURN_SPEED);
}

static void executeDetourLeftCCW(void)
{
    /* Turn left onto side line */
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(-TURN_SPEED, TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(-TURN_SPEED, TURN_SPEED);

    /* Stop and wait 2 seconds for stable colour reading */
    setMotors(0, 0);
    delay_ms(2000);

    /* Read colour and move servo accordingly:
     * RED  â?? Clockwise
     * BLUE â?? Counter-clockwise */
    Color detected = readColor();
    if (detected == COLOR_RED)
        servoClockwise();
    else if (detected == COLOR_BLUE)
        servoCounterClockwise();

    /* Turn right to rejoin main line */
    setMotors(OVERSHOOT_SPEED, OVERSHOOT_SPEED);
    delay_ms(JUNCTION_OVERSHOOT_MS);

    setMotors(TURN_SPEED, -TURN_SPEED);
    delay_ms(TURN_SETTLE_MS);

    while (PIN_C == 0)
        setMotors(TURN_SPEED, -TURN_SPEED);
}


/* ================================================================
 *  Persistent state
 * ================================================================ */
static int8_t  lastTurnDir   =  1;
static uint8_t inGap         =  0;
static uint32_t gapStart     =  0;

/* Junction debounce */
typedef enum { JD_IDLE, JD_CONFIRMING, JD_COOLDOWN } JuncDebState;
static JuncDebState jdState       = JD_IDLE;
static uint32_t     jdTimer       = 0;
static uint8_t      junctionCount = 0;


/* ================================================================
 *  main()
 * ================================================================ */
void main(void)
{
    TRISD  = 0x00;
    TRISB  = 0xFF;
    TRISC  = 0xFF;
    TRISA  = 0x10;      // RA0-RA3 output (TCS S0-S3), RA4 input (TCS OUT)
    ADCON1 = 0x0F;

    OSCCON = 0x72;

    PWM_Init();
    TCS_Init();
    Timer0_Init();

    setMotors(0, 0);
    delay_ms(STARTUP_HOLD_MS);


    while (1)
    {
        /* 1. Read sensors */
        uint8_t LL = (uint8_t)PIN_LL;
        uint8_t L  = (uint8_t)PIN_L;
        uint8_t C  = (uint8_t)PIN_C;
        uint8_t R  = (uint8_t)PIN_R;
        uint8_t RR = (uint8_t)PIN_RR;
        uint8_t sensorSum = LL + L + C + R + RR;

        /* 2. Junction debounce state machine */
        uint8_t jTrigger = ((LL || RR) && (sensorSum >= 3)) ? 1u : 0u;

        switch (jdState)
        {
            case JD_IDLE:
                if (jTrigger)
                {
                    jdState = JD_CONFIRMING;
                    jdTimer = millis();
                }
                break;

            case JD_CONFIRMING:
                if (!jTrigger)
                {
                    jdState = JD_IDLE;
                }
                else if (millis() - jdTimer >= JUNCTION_CONFIRM_MS)
                {
                    jdState = JD_COOLDOWN;
                    jdTimer = millis();

                    if (junctionCount < PATH_LENGTH)
                    {
                        Action action = path[junctionCount];
                        junctionCount++;

                        if (action == ROUTE_END)
                        {
                            setMotors(0, 0);
                            while (1);
                        }
                        else if (action == TURN_LEFT)
                        {
                            executeTurnLeft();
                            lastTurnDir =  -1;
                            inGap       =   0;
                            jdTimer     = millis();
                        }
                        else if (action == TURN_RIGHT)
                        {
                            executeTurnRight();
                            lastTurnDir =  1;
                            inGap       =  0;
                            jdTimer     = millis();
                        }
                        else if (action == DETOUR_LEFT_CW)
                        {
                            executeDetourLeftCW();
                            lastTurnDir =  -1;
                            inGap       =   0;
                            jdTimer     = millis();
                        }
                        else if (action == DETOUR_LEFT_CCW)
                        {
                            executeDetourLeftCCW();
                            lastTurnDir =  -1;
                            inGap       =   0;
                            jdTimer     = millis();
                        }
                    }
                }
                break;

            case JD_COOLDOWN:
                if (millis() - jdTimer >= JUNCTION_COOLDOWN_MS)
                    jdState = JD_IDLE;
                break;
        }

        /* 3. Lost-line / gap recovery */
        if (sensorSum == 0)
        {
            if (!inGap) { inGap = 1; gapStart = millis(); }

            if (millis() - gapStart < GAP_COAST_TIME)
                setMotors(BASE_SPEED, BASE_SPEED);
            else if (lastTurnDir == 1)
                setMotors( RECOVERY_SPEED, -RECOVERY_SPEED);
            else
                setMotors(-RECOVERY_SPEED,  RECOVERY_SPEED);

            continue;
        }

        inGap = 0;

        /* 4. Weighted position error */
        int16_t error = ((int16_t)RR *  4)
                      + ((int16_t)R  *  2)
                      - ((int16_t)L  *  2)
                      - ((int16_t)LL *  4);

        if      (error >  DIR_THRESHOLD) lastTurnDir =  1;
        else if (error < -DIR_THRESHOLD) lastTurnDir = -1;

        /* 5. P-controller */
        int16_t correction = (int16_t)KP * error;
        setMotors(BASE_SPEED + correction,
                  BASE_SPEED - correction);
    }
}
